# URL pública del proyecto Supabase
# Encontrala en: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon/public de Supabase (segura para exponer al browser)
# Encontrala en: Supabase Dashboard → Project Settings → API → Project API Keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de service role (SOLO para scripts de administración del lado del servidor)
# NUNCA exponerla al cliente ni commitearla. Rotar si se filtra.
# Encontrala en: Supabase Dashboard → Project Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
